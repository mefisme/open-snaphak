# Build artifacts -- the source is the deliverable; the DLLs are rebuilt via build-backend.ps1 /
# build-qt.ps1 / build-webview.ps1, and the deployable overlay bundle is assembled into dist/ by
# package-qt.ps1 (Qt) or package-webview.ps1 (webview).
build/
dist/
*.obj
*.dll
*.exe
*.lib
*.exp
*.pdb
*.ilk
*.cod
*.log

# Local Claude Code config (per-machine; not part of the public package)
.claude/

# Personal local-dev convenience script (not for upstream)
/sync-and-build-webview.ps1
